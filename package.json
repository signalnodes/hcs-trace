{
  "name": "hcs-trace",
  "version": "0.1.0",
  "description": "CLI tool to query, tail, decode, export, and analyze HCS topic streams with automatic standards detection",
  "type": "module",
  "bin": {
    "hcs-trace": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));\" && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/signalnodes/hcs-trace.git"
  },
  "homepage": "https://github.com/signalnodes/hcs-trace#readme",
  "bugs": {
    "url": "https://github.com/signalnodes/hcs-trace/issues"
  },
  "keywords": ["hedera", "hcs", "consensus", "cli", "inspector", "debugger"],
  "license": "MIT"
}
